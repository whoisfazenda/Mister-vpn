# ───────────────────────── Telegram ─────────────────────────
# Токен бота от @BotFather
BOT_TOKEN=
# Telegram ID администраторов через запятую, например: 123456789,987654321
ADMIN_IDS=

# ───────────────────────── Database ─────────────────────────
# Для docker-compose host = db. Для локального запуска замените на localhost.
# Pterodactyl MySQL: mysql+aiomysql://USER:PASSWORD@HOST:3306/DB_NAME
DATABASE_URL=postgresql+asyncpg://vpn_user:vpn_password@db:5432/vpn_db

# Учётные данные Postgres для контейнера db (docker-compose)
POSTGRES_USER=vpn_user
POSTGRES_PASSWORD=vpn_password
POSTGRES_DB=vpn_db

# ───────────────────────── AdaptGroup VPN API ───────────────
ADAPTGROUP_BASE_URL=https://network-api.adaptgroup.app
ADAPTGROUP_API_KEY=
ADAPTGROUP_API_KEY_ID=
ADAPTGROUP_WEBHOOK_SECRET=
# Таймаут HTTP-запросов к AdaptGroup, секунды
ADAPTGROUP_TIMEOUT=20

# ───────────────────────── Payments ─────────────────────────
# Сейчас доступен только mock. Позже: yookassa / stripe / cryptobot и т.д.
PAYMENT_PROVIDER=mock
# Валюта заказов по умолчанию
CURRENCY=RUB
# AdaptGroup отдаёт закупочные цены в USD; бот продаёт пользователю в RUB.
ADAPTGROUP_USD_TO_RUB_RATE=76.142857
PLAN_MARKUP_PERCENT=30
# Розничная цена 1 ГБ для докупки трафика в выбранной валюте
TRAFFIC_PRICE_PER_GB=3
MIN_BALANCE_TOPUP=100
MAX_BALANCE_TOPUP=50000
# Обязательная подписка на канал. Пример ID: @channel_name или -1001234567890.
REQUIRED_CHANNEL_ID=
REQUIRED_CHANNEL_URL=

# UUID 7-дневного тарифа AdaptGroup для бесплатного пробного периода.
# Если пусто, бот попробует сам найти активный 7-дневный тариф с "test"/"тест" в названии.
FREE_TRIAL_PLAN_UUID=

# RollyPay (PAYMENT_PROVIDER=rollypay)
ROLLYPAY_BASE_URL=https://rollypay.io
ROLLYPAY_API_KEY=
# Необязательно при API key: касса определяется по ключу.
ROLLYPAY_TERMINAL_ID=
# Нужен только для автоматических webhook-уведомлений /webhooks/rollypay.
ROLLYPAY_SIGNING_SECRET=
# Необязательно: sbp/card/intl_card/crypto. Пусто = выбор на странице оплаты.
ROLLYPAY_PAYMENT_METHOD=
ROLLYPAY_SUCCESS_REDIRECT_URL=
ROLLYPAY_FAIL_REDIRECT_URL=
ROLLYPAY_TIMEOUT=20

# YooKassa SBP #2 (extra balance top-up method)
YOOKASSA_BASE_URL=https://api.yookassa.ru
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Where YooKassa returns the user after payment. Can be your bot/site URL.
YOOKASSA_RETURN_URL=
YOOKASSA_TIMEOUT=20

# ───────────────────────── App ──────────────────────────────
# DEV_MODE=true включает ручное подтверждение оплаты тестовых заказов.
# В проде ОБЯЗАТЕЛЬНО false.
DEV_MODE=false

# Ссылка на поддержку (https://t.me/your_support или https://...)
SUPPORT_URL=https://t.me/your_support
# Публичный базовый URL сервиса вебхуков (для справки/README), например https://vpn.example.com
PUBLIC_BASE_URL=
# Хост/порт FastAPI-сервиса вебхуков
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
# Необязательный whitelist IP AdaptGroup через запятую (доп. слой, НЕ единственный)
ADAPTGROUP_WEBHOOK_ALLOWED_IPS=

# Время жизни кэша тарифов, секунды
PLANS_CACHE_TTL=300

# Как часто бот проверяет подписки и отправляет напоминания об окончании.
REMINDER_CHECK_INTERVAL_SECONDS=21600

LOG_LEVEL=INFO
