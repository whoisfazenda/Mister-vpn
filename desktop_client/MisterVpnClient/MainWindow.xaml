<Window x:Class="MisterVpnClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mister VPN" Height="650" Width="945"
        MinHeight="620" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#101012"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False">
    <Window.Resources>
        <SolidColorBrush x:Key="Panel" Color="#171719"/>
        <SolidColorBrush x:Key="Panel2" Color="#202023"/>
        <SolidColorBrush x:Key="Line" Color="#2B2B30"/>
        <SolidColorBrush x:Key="Text" Color="#F2F2F4"/>
        <SolidColorBrush x:Key="Muted" Color="#777982"/>
        <SolidColorBrush x:Key="Cyan" Color="#48F6E7"/>

        <DropShadowEffect x:Key="SoftShadow" BlurRadius="24" ShadowDepth="10" Opacity="0.35" Color="#000000"/>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
            <Setter Property="Background" Value="#1A1A1D"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}, FallbackValue=18}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#F4F4F6"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Background" Value="#0D0D0F"/>
            <Setter Property="BorderBrush" Value="#34343A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#25252A" BorderThickness="1" Background="#101012">
        <Grid MouseLeftButtonDown="WindowDrag_MouseLeftButtonDown">
            <Grid.Background>
                <RadialGradientBrush Center="0.5,0.55" GradientOrigin="0.5,0.55" RadiusX="0.92" RadiusY="0.76">
                    <GradientStop Color="#17171A" Offset="0"/>
                    <GradientStop Color="#111114" Offset="0.58"/>
                    <GradientStop Color="#0C0C0E" Offset="1"/>
                </RadialGradientBrush>
            </Grid.Background>

            <Canvas Opacity="0.34" IsHitTestVisible="False">
                <ItemsControl>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <Ellipse Width="4" Height="4" Fill="#323239" Canvas.Left="95" Canvas.Top="220"/>
                    <Ellipse Width="3" Height="3" Fill="#3E3E47" Canvas.Left="180" Canvas.Top="260"/>
                    <Ellipse Width="4" Height="4" Fill="#303039" Canvas.Left="250" Canvas.Top="330"/>
                    <Ellipse Width="3" Height="3" Fill="#3C3C45" Canvas.Left="365" Canvas.Top="255"/>
                    <Ellipse Width="4" Height="4" Fill="#383842" Canvas.Left="480" Canvas.Top="360"/>
                    <Ellipse Width="3" Height="3" Fill="#32323A" Canvas.Left="570" Canvas.Top="250"/>
                    <Ellipse Width="4" Height="4" Fill="#363640" Canvas.Left="690" Canvas.Top="315"/>
                    <Ellipse Width="3" Height="3" Fill="#383842" Canvas.Left="805" Canvas.Top="245"/>
                    <Ellipse Width="4" Height="4" Fill="#34343E" Canvas.Left="130" Canvas.Top="480"/>
                    <Ellipse Width="3" Height="3" Fill="#42424B" Canvas.Left="305" Canvas.Top="515"/>
                    <Ellipse Width="4" Height="4" Fill="#363640" Canvas.Left="640" Canvas.Top="500"/>
                    <Ellipse Width="3" Height="3" Fill="#3E3E48" Canvas.Left="790" Canvas.Top="455"/>
                </ItemsControl>
            </Canvas>

            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="42"/>
                    <RowDefinition/>
                    <RowDefinition Height="44"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="◢" Foreground="#D9D9DE" FontSize="17" Margin="0,0,12,0"/>
                        <TextBlock Text="Mister VPN" Foreground="#EDEDF0" FontSize="16"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="−" Width="38" Height="30" FontSize="18" Background="Transparent" BorderBrush="Transparent" Click="MinimizeButton_Click"/>
                        <Button Content="□" Width="38" Height="30" FontSize="13" Background="Transparent" BorderBrush="Transparent" Click="MaximizeButton_Click"/>
                        <Button Content="×" Width="38" Height="30" FontSize="18" Background="Transparent" BorderBrush="Transparent" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,8,0,0">
                        <Border Width="184" Height="42" CornerRadius="21" Background="#141417" BorderBrush="#2A2A2F" BorderThickness="1" Padding="5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="GameModePill" Grid.Column="0" Background="#2B2B30" CornerRadius="17">
                                    <TextBlock Text="Game" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="TUN" Foreground="#8A8B92" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,10">
                        <Button x:Name="PowerButton" Width="190" Height="190" Tag="95"
                                Background="#242428" BorderBrush="#232328"
                                Effect="{StaticResource SoftShadow}"
                                Click="PowerButton_Click">
                            <TextBlock x:Name="PowerIcon" Text="⏻" FontSize="58" Foreground="#B8B9C2" FontWeight="Light"/>
                        </Button>

                        <TextBlock x:Name="StatusText" Text="Отключено"
                                   Foreground="{StaticResource Muted}" FontSize="15"
                                   HorizontalAlignment="Center" Margin="0,82,0,0"/>

                        <Border Background="#171719" BorderBrush="#2B2B30" BorderThickness="1"
                                CornerRadius="22" Padding="16,10" HorizontalAlignment="Center" Margin="0,14,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="22" Height="22" Stroke="#111" StrokeThickness="1">
                                    <Ellipse.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#000000" Offset="0"/>
                                            <GradientStop Color="#DD0000" Offset="0.50"/>
                                            <GradientStop Color="#FFCE00" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock x:Name="ServerText" Text="Germany" Foreground="#F2F2F4" FontSize="16" Margin="12,0,14,0"/>
                                <Ellipse Width="7" Height="7" Fill="{StaticResource Cyan}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="PingText" Text=" -- ms" Foreground="{StaticResource Cyan}" FontSize="13" Margin="7,1,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#141417" BorderBrush="#26262C" BorderThickness="1"
                                CornerRadius="27" Padding="14,10" HorizontalAlignment="Center" Margin="0,30,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="▦" Width="58" Height="34" FontSize="18" Background="Transparent" BorderBrush="Transparent" Click="TogglePanelButton_Click"/>
                                <Button Content="▾" Width="58" Height="34" FontSize="18" Background="Transparent" BorderBrush="Transparent"/>
                                <Button Content="⚙" Width="58" Height="34" FontSize="18" Background="Transparent" BorderBrush="Transparent" Click="TogglePanelButton_Click"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border x:Name="SubscriptionPanel" Width="420" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Background="#151518" BorderBrush="#2C2C32" BorderThickness="1"
                            CornerRadius="22" Padding="18" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Ссылка подписки" Foreground="#F3F3F5" FontWeight="Black" FontSize="16"/>
                            <TextBox x:Name="SubscriptionBox" Height="82" Margin="0,12,0,0"
                                     TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                            <CheckBox x:Name="SystemProxyCheckBox" Content="Включать системный прокси Windows"
                                      IsChecked="True" Foreground="#DADAE0" Margin="0,12,0,0"/>
                            <Button Content="Сохранить" Height="40" Margin="0,12,0,0" Click="SaveButton_Click"/>
                            <TextBox x:Name="LogBox" Height="116" Margin="0,12,0,0"
                                     Background="#0B0B0D" BorderBrush="#2B2B30"
                                     IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="2">
                    <StackPanel VerticalAlignment="Bottom">
                        <TextBlock Text="Mister VPN v0.1.0" Foreground="#666873" FontSize="11"/>
                        <TextBlock Text="by Mister VPN" Foreground="#4F515B" FontSize="10"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <Thumb Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Cursor="SizeNWSE" DragDelta="ResizeThumb_DragDelta" Opacity="0"/>
        </Grid>
    </Border>
</Window>
